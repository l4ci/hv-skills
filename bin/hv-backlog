#!/usr/bin/env bash
# Render pre-sorted backlog tables from .hv/TODO.md, excluding items active in status.json.
# Output: markdown — "In Progress" + "Bugs" (P0/P1/P2) + "Features" (Cosmetic/Minor/Major) + "Tasks".
# Empty sections are omitted. Prints a placeholder if the whole backlog is empty.
# Usage: hv-backlog
set -euo pipefail
python3 - <<'PY'
import json, re
from pathlib import Path

todo_path = Path(".hv/TODO.md")
if not todo_path.exists():
    print("No .hv/TODO.md yet. Run /hv-init then /hv-capture.")
    raise SystemExit(0)
content = todo_path.read_text()

status_path = Path(".hv/status.json")
active_entries, active_ids = [], set()
if status_path.exists():
    data = json.loads(status_path.read_text())
    for entry in data.get("active", []):
        active_entries.append(entry)
        for i in entry.get("items", []):
            active_ids.add(i)

def section_body(name):
    m = re.search(rf"^## {re.escape(name)}\s*$", content, re.MULTILINE)
    if not m:
        return ""
    start = m.end()
    nxt = re.search(r"^## ", content[start:], re.MULTILINE)
    return content[start:start + nxt.start()] if nxt else content[start:]

def parse_items(body):
    items = []
    for line in body.splitlines():
        line = line.strip()
        if not line.startswith("- **["):
            continue
        idm = re.match(r"- \*\*\[([BFT]\d+)\]", line)
        if not idm:
            continue
        item_id = idm.group(1)
        # Strip the ID+tag prefix so title parsing works even when titles contain periods.
        # Entry format: "- **[ID] [tag] Title.** Desc..." or "- **[ID] Title.** Desc..."
        after_id = re.sub(r"^- \*\*\[[BFT]\d+\]\s*(?:\[(?:P[012]|Major|Minor|Cosmetic)\]\s*)?", "", line)
        tagm = re.search(r"\[(P[012]|Major|Minor|Cosmetic)\]", line)
        tag = tagm.group(1) if tagm else ""
        titlem = re.match(r"(.+?)\.\*\*", after_id)
        title = titlem.group(1).strip() if titlem else "?"
        relm = re.search(r"Related:\s*([^\n]*?)(?:\s+(?:Detail|Milestone):|$)", line)
        related = relm.group(1).strip().rstrip(".") if relm else ""
        msm = re.search(r"Milestone:\s*([^\n]*?)(?:\s+(?:Detail|Related):|$)", line)
        milestones = ", ".join(re.findall(r"M\d+", msm.group(1))) if msm else ""
        items.append({"id": item_id, "tag": tag, "title": title, "related": related, "milestone": milestones})
    return items

bugs = [i for i in parse_items(section_body("Bugs")) if i["id"] not in active_ids]
features = [i for i in parse_items(section_body("Features")) if i["id"] not in active_ids]
tasks = [i for i in parse_items(section_body("Tasks")) if i["id"] not in active_ids]

prio = {"P0": 0, "P1": 1, "P2": 2, "": 3}
size = {"Cosmetic": 0, "Minor": 1, "Major": 2, "": 3}
bugs.sort(key=lambda x: prio.get(x["tag"], 3))
features.sort(key=lambda x: size.get(x["tag"], 3))

def title_of(item_id):
    m = re.search(rf"\*\*\[{re.escape(item_id)}\][^*]*\*\*", content)
    if not m:
        return "?"
    tm = re.search(r"\]\s+([^.]+?)\.", m.group(0))
    return tm.group(1).strip() if tm else "?"

out = []

if active_entries:
    out.append("### In Progress\n")
    out.append("| ID | Title | Branch | Started |")
    out.append("|----|-------|--------|---------|")
    for e in active_entries:
        branch = e.get("branch", "")
        started = (e.get("startedAt") or "")[:10]
        for iid in e.get("items", []):
            out.append(f"| {iid} | {title_of(iid)} | {branch} | {started} |")
    out.append("")

def render_table(label, items, base_headers, row_fn):
    if not items:
        return
    show_ms = any(i["milestone"] for i in items)
    headers = list(base_headers) + (["Milestone"] if show_ms else [])
    out.append(f"### {label}\n")
    out.append("| " + " | ".join(headers) + " |")
    out.append("|" + "|".join("----" for _ in headers) + "|")
    for i in items:
        row = row_fn(i) + ([i["milestone"]] if show_ms else [])
        out.append("| " + " | ".join(row) + " |")
    out.append("")

render_table("Bugs", bugs, ["ID", "Prio", "Title", "Related"],
             lambda i: [i["id"], i["tag"], i["title"], i["related"]])
render_table("Features", features, ["ID", "Size", "Title", "Related"],
             lambda i: [i["id"], i["tag"], i["title"], i["related"]])
render_table("Tasks", tasks, ["ID", "Title", "Related"],
             lambda i: [i["id"], i["title"], i["related"]])

if not (active_entries or bugs or features or tasks):
    out.append("Backlog empty. Run /hv-capture to add items.")

print("\n".join(out))
PY
