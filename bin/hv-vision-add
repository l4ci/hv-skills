#!/usr/bin/env bash
# Add a new milestone — mints ID via hv-next-id, creates .hv/milestones/MNN.md,
# appends an overview entry to .hv/MILESTONES.md. Status starts as "planned".
# Usage: hv-vision-add "<title>" "<summary>" [depends-csv]
# Prints the new milestone ID on stdout.
set -euo pipefail
TITLE="${1:?usage: hv-vision-add <title> <summary> [depends-csv]}"
SUMMARY="${2:?usage: hv-vision-add <title> <summary> [depends-csv]}"
DEPENDS="${3:-}"
HERE="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
MID=$("$HERE/hv-next-id" milestones)
python3 - "$MID" "$TITLE" "$SUMMARY" "$DEPENDS" <<'PY'
import re, sys
from datetime import date
from pathlib import Path

mid, title, summary, depends_csv = sys.argv[1], sys.argv[2], sys.argv[3], sys.argv[4]

depends = [d.strip() for d in depends_csv.split(",") if d.strip()]
depends_yaml = "[" + ", ".join(depends) + "]"
depends_overview = ", ".join(depends) if depends else "—"

detail_path = Path(f".hv/milestones/{mid}.md")
detail_path.parent.mkdir(parents=True, exist_ok=True)
detail_path.write_text(
    f"""---
id: {mid}
title: {title}
status: planned
depends: {depends_yaml}
created: {date.today().isoformat()}
---

# {mid} — {title}

## Goal

{summary}

## Acceptance criteria

- _(define what shipped looks like)_

## Rationale

_(why this milestone, why now)_

## Open risks

_(unknowns, technical risks, dependencies that could shift)_

## Research findings

_(prior art, references, lessons from /hv-vision web search)_

## Notes

_(free-form brainstorm)_
"""
)

ms_path = Path(".hv/MILESTONES.md")
content = ms_path.read_text() if ms_path.exists() else ""

section = (
    f"\n### {mid} — {title}\n\n"
    f"**Status:** planned · **Depends:** {depends_overview}\n\n"
    f"{summary}\n\n"
    f"[Full plan: `.hv/milestones/{mid}.md`]\n"
)

if re.search(r"^## Milestones\s*$", content, re.MULTILINE):
    content = content.rstrip("\n") + "\n" + section
else:
    content = content.rstrip("\n") + ("\n\n" if content.strip() else "") + "## Milestones\n" + section

ms_path.write_text(content if content.endswith("\n") else content + "\n")
print(mid)
PY
