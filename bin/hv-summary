#!/usr/bin/env bash
# Print a compact project-state summary: backlog counts, active work,
# recent completions, knowledge topics. Pure read — no git calls, no mutation.
# Usage: hv-summary
set -euo pipefail
python3 - <<'PY'
import json, re
from pathlib import Path

todo = Path(".hv/TODO.md")
if not todo.exists():
    print("No .hv/ yet — run /hv:init.")
    raise SystemExit(0)
content = todo.read_text()

def section(name):
    m = re.search(rf"^## {re.escape(name)}\s*$", content, re.MULTILINE)
    if not m:
        return ""
    start = m.end()
    nxt = re.search(r"^## ", content[start:], re.MULTILINE)
    return content[start:start + nxt.start()] if nxt else content[start:]

def count(body):
    return sum(1 for line in body.splitlines() if line.strip().startswith("- **["))

def pluralize(n, singular, plural=None):
    return f"{n} {singular if n == 1 else (plural or singular + 's')}"

bugs = count(section("Bugs"))
features = count(section("Features"))
tasks = count(section("Tasks"))
print(f"Backlog: {pluralize(bugs, 'bug')}, {pluralize(features, 'feature')}, {pluralize(tasks, 'task')}")

# Active work
status = Path(".hv/status.json")
if status.exists():
    try:
        data = json.loads(status.read_text())
    except json.JSONDecodeError:
        data = {"active": []}
    for entry in data.get("active", []):
        ids = ", ".join(entry.get("items", [])) or "?"
        branch = entry.get("branch", "?")
        started = (entry.get("startedAt") or "")[:10]
        wt = entry.get("worktree")
        loc = f" in {wt}" if wt else ""
        print(f"Active: {ids} on {branch}{loc} (since {started})")

# Recent completions (top 3 from ## Completed)
completed = section("Completed")
pairs = re.findall(r"(\[[BFT]\d+\])[^[\n]*?Done (\d{4}-\d{2}-\d{2})", completed)
if pairs:
    recent = pairs[:3]
    print("Recent: " + ", ".join(f"{iid} on {d}" for iid, d in recent))

# Knowledge topics
k = Path(".hv/KNOWLEDGE.md")
if k.exists():
    topics = re.findall(r"^## (.+?)\s*$", k.read_text(), re.MULTILINE)
    if topics:
        shown = topics[:4]
        suffix = ", ..." if len(topics) > 4 else ""
        print(f"Knowledge: {len(topics)} topics ({', '.join(shown)}{suffix})")

# Archive size
a = Path(".hv/ARCHIVE.md")
if a.exists():
    n = sum(1 for line in a.read_text().splitlines() if re.match(r"- ~~", line))
    if n:
        print(f"Archive: {n} older item{'s' if n != 1 else ''}")
PY
