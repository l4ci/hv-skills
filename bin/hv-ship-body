#!/usr/bin/env bash
# Build a PR body for a branch: "## Summary" (commit subjects) and
# "## Items resolved" (IDs with titles pulled from TODO.md / ARCHIVE.md).
# Skips merge commits. Caller appends "## Test plan".
# Usage: hv-ship-body <branch>
# Prints: markdown body on stdout.
set -euo pipefail
BRANCH="${1:?usage: hv-ship-body <branch>}"

BASE=""
for candidate in main master trunk; do
  if git rev-parse --verify "$candidate" >/dev/null 2>&1; then
    BASE="$candidate"
    break
  fi
done
if [ -z "$BASE" ]; then
  REMOTE_HEAD=$(git symbolic-ref refs/remotes/origin/HEAD 2>/dev/null || true)
  [ -n "$REMOTE_HEAD" ] && BASE="${REMOTE_HEAD#refs/remotes/origin/}"
fi
if [ -z "$BASE" ]; then
  echo "error: could not determine base branch" >&2
  exit 1
fi

git rev-parse --verify "$BRANCH" >/dev/null 2>&1 || {
  echo "error: branch '$BRANCH' not found" >&2
  exit 1
}

export HV_BRANCH="$BRANCH" HV_BASE="$BASE"
HV_SUBJECTS=$(git log --no-merges --format='%s' "$BASE..$BRANCH")
HV_BODIES=$(git log --no-merges --format='%B' "$BASE..$BRANCH")
export HV_SUBJECTS HV_BODIES

python3 - <<'PY'
import os, re, sys
from pathlib import Path

branch = os.environ["HV_BRANCH"]
subjects = [l for l in os.environ["HV_SUBJECTS"].splitlines() if l.strip()]
full = os.environ["HV_BODIES"]

if not subjects:
    print(f"error: no commits between base and {branch}", file=sys.stderr)
    sys.exit(1)

print("## Summary")
print()
for line in subjects:
    print(f"- {line.strip()}")
print()

id_re = re.compile(r"\[([BFT]\d{2,})\]")
seen, ordered = set(), []
for match in id_re.finditer(full):
    iid = match.group(1)
    if iid not in seen:
        seen.add(iid)
        ordered.append(iid)

if not ordered:
    sys.exit(0)

def read(p):
    path = Path(p)
    return path.read_text() if path.exists() else ""

corpus = read(".hv/TODO.md") + "\n" + read(".hv/ARCHIVE.md")

def title_for(iid):
    pat = re.compile(
        rf"\[{re.escape(iid)}\](?:\s+\[[^\]]+\])?\s+(?P<t>[^.\n]+)\."
    )
    m = pat.search(corpus)
    return m.group("t").strip() if m else None

print("## Items resolved")
print()
for iid in ordered:
    title = title_for(iid)
    print(f"- [{iid}] {title}" if title else f"- [{iid}]")
print()
PY
