#!/usr/bin/env bash
# Create a plan file under .hv/plans/<milestone>-<unit>.md.
# Usage:
#   hv-plan-add <milestone> slice "<title>"        — mints next S<NN> for that milestone
#   hv-plan-add <milestone> <itemId> "<title>"     — uses item ID (B07, F03, T11, S01, …) verbatim
# Prints the full plan key on stdout (e.g. "M01-S03" or "M01-B07").
set -euo pipefail
MILESTONE="${1:?usage: hv-plan-add <milestone> <unit-or-slice> <title>}"
UNIT="${2:?usage: hv-plan-add <milestone> <unit-or-slice> <title>}"
TITLE="${3:?usage: hv-plan-add <milestone> <unit-or-slice> <title>}"
python3 - "$MILESTONE" "$UNIT" "$TITLE" <<'PY'
import re, sys
from datetime import date
from pathlib import Path

milestone, unit_in, title = sys.argv[1], sys.argv[2], sys.argv[3]

if not re.fullmatch(r"M\d{2,}", milestone):
    print(f"error: milestone must look like M01/M02/…, got {milestone!r}", file=sys.stderr)
    sys.exit(1)

plans_dir = Path(".hv/plans")
plans_dir.mkdir(parents=True, exist_ok=True)

if unit_in == "slice":
    existing = sorted(plans_dir.glob(f"{milestone}-S*.md"))
    nums = []
    for p in existing:
        m = re.match(rf"{re.escape(milestone)}-S(\d+)", p.stem)
        if m:
            nums.append(int(m.group(1)))
    next_n = (max(nums) + 1) if nums else 1
    unit = f"S{next_n:02d}"
    unit_kind = "slice"
else:
    if not re.fullmatch(r"[BFTS]\d{2,}", unit_in):
        print(f"error: unit must be 'slice' or an ID like B07/F03/T11/S02, got {unit_in!r}", file=sys.stderr)
        sys.exit(1)
    unit = unit_in
    unit_kind = "slice" if unit.startswith("S") else "item"

key = f"{milestone}-{unit}"
plan_path = plans_dir / f"{key}.md"
if plan_path.exists():
    print(f"error: {plan_path} already exists", file=sys.stderr)
    sys.exit(1)

plan_path.write_text(
    f"""---
key: {key}
milestone: {milestone}
unit: {unit}
unitKind: {unit_kind}
title: {title}
status: planned
created: {date.today().isoformat()}
---

# {key} — {title}

## Goal

_(one sentence — what shipping this means)_

## Approach

_(3–6 sentences — the shape of the implementation, the design choice, why this over alternatives)_

## Tasks

- **T1** — _(observable behavior)_
  - Files: _(paths the orchestrator will touch or create)_
  - Verify: _(command or manual check that proves T1 done)_

## Open questions

- _(unresolved decisions — answer before or during execution)_

## Assumptions

- _(named assumptions made implicit by the approach)_
"""
)
print(key)
PY
